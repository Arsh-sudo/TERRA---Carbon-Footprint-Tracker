rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // Hardened Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Validation for UserProfile Document
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'name', 'photoURL', 'joinedDate', 'ecoPoints', 'totalSavedCO2', 'dailyStreak', 'weeklyTarget'])
          && data.keys().size() == 8
          && data.uid == request.auth.uid
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.photoURL is string && data.photoURL.size() <= 1000
          && data.joinedDate is string && data.joinedDate.size() <= 20
          && data.ecoPoints is number && data.ecoPoints >= 0
          && data.totalSavedCO2 is number && data.totalSavedCO2 >= 0
          && data.dailyStreak is number && data.dailyStreak >= 0
          && data.weeklyTarget is number && data.weeklyTarget >= 0.1;
    }

    // Validation for Feedback Document
    function isValidFeedback(data) {
      return data.keys().hasAll(['userId', 'email', 'name', 'category', 'description', 'createdAt'])
          && (data.keys().size() == 6 || (data.keys().size() == 7 && data.keys().hasAny(['screenshot'])))
          && data.userId == request.auth.uid
          && data.email is string && data.email.size() > 0 && data.email.size() <= 256
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.category is string && (data.category == 'feedback' || data.category == 'question' || data.category == 'bug' || data.category == 'suggestion')
          && data.description is string && data.description.size() > 0 && data.description.size() <= 10000
          && (!data.keys().hasAny(['screenshot']) || (data.screenshot is string && data.screenshot.size() <= 5000000))
          && data.createdAt is string && data.createdAt.size() <= 100;
    }

    // Users Collection rules
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      // We also allow list querying if authenticated and requesting their own doc only
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid && isValidId(userId);
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(request.resource.data);
      allow delete: if false; // Profiles cannot be deleted client-side
    }

    // Feedback Collection rules
    match /feedback/{feedbackId} {
      // Feedback submissions are strictly write-only (create) by the authenticated user for data privacy.
      allow create: if isSignedIn() && isValidFeedback(request.resource.data) && isValidId(feedbackId);
      allow read, update, delete: if false;
    }
  }
}
